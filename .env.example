# Configuración de base de datos
MYSQLHOST=localhost
MYSQLPORT=3306
MYSQLDATABASE=odontofy
MYSQLUSER=root
MYSQLPASSWORD=your_secure_password

# JWT Secret - ¡IMPORTANTE! Cambia esto en producción
SECRETORPRIVATEKEY=your_super_secure_jwt_secret_key_here

# URLs de la aplicación
BACKEND_URL=http://localhost:8000
FRONTEND_URL=http://localhost:4200

# Google Cloud Storage
GCS_BUCKET_NAME=your_gcs_bucket_name

# Google OAuth
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# Email service (Brevo/SendGrid)
BREVO_API_KEY=your_brevo_api_key
BREVO_FROM_EMAIL=noreply@yourdomain.com
BREVO_FROM_NAME=Odontofy

# Configuración de logging
LOG_LEVEL=info
NODE_ENV=development

# Puerto del servidor
PORT=8000